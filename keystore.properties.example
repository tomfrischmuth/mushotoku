# Template for the release signing configuration.
#
# 1. Copy this file to "keystore.properties" (it lives in the project root
#    and is NOT checked in – see .gitignore).
# 2. Fill in the values and generate a keystore (see README / keytool command).
#
# storeFile     : Path to the keystore file (relative to the project root or absolute)
# storePassword : Password for the keystore
# keyAlias      : Alias of the key within the keystore
# keyPassword   : Password for the key (identical to storePassword)

storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=mushotoku
keyPassword=CHANGE_ME
